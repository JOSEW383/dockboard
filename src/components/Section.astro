---
import type { Section as SectionType } from '../pages/api/config';
import ServiceCard from './ServiceCard.astro';

interface Props {
  section: SectionType;
}
const { section } = Astro.props;
---

<section class="mb-6" data-section-name={section.name}>
  <button
    type="button"
    class="section-toggle w-full flex items-center gap-3 mb-4 group"
    aria-expanded="true"
  >
    <svg
      class="section-chevron w-3.5 h-3.5 shrink-0 text-zinc-400 dark:text-zinc-500 transition-transform duration-200"
      viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
    >
      <polyline points="6 9 12 15 18 9"/>
    </svg>
    <h2 class="text-xs font-semibold uppercase tracking-widest text-zinc-500 dark:text-zinc-400 group-hover:text-zinc-700 dark:group-hover:text-zinc-300 transition-colors">
      {section.name}
    </h2>
    <div class="flex-1 h-px bg-zinc-200 dark:bg-zinc-800"></div>
    <span class="section-counter text-xs tabular-nums font-medium text-zinc-400 dark:text-zinc-600" data-total={section.items.length}>…/{section.items.length}</span>
  </button>

  <div class="section-body services-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3">
    {section.items.map((item) => (
      <ServiceCard item={item} />
    ))}
  </div>
</section>
