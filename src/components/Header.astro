---
interface Props {
  title: string;
  subtitle?: string;
  icon?: string;
}
const { title, subtitle, icon } = Astro.props;
const iconSrc = icon ? `/icons/${icon}` : null;
---

<header class="border-b border-zinc-200 dark:border-zinc-800 bg-white/80 dark:bg-zinc-950/80 backdrop-blur-sm sticky top-0 z-10">
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 py-3 flex items-center gap-3">
    <!-- Logo mark -->
    <div class="flex items-center justify-center w-8 h-8 rounded-lg bg-zinc-100 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 shrink-0 overflow-hidden">
      {iconSrc ? (
        <img src={iconSrc} alt={title} class="w-8 h-8 object-contain" />
      ) : (
        <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 text-zinc-600 dark:text-zinc-300" stroke="currentColor" stroke-width="2">
          <rect x="2" y="3" width="20" height="14" rx="2" />
          <path d="M8 21h8M12 17v4" />
        </svg>
      )}
    </div>

    <!-- Title -->
    <div class="min-w-0 flex-1">
      <h1 class="text-base font-semibold text-zinc-900 dark:text-zinc-100 leading-tight truncate">{title}</h1>
      {subtitle && (
        <p class="text-xs text-zinc-500 leading-tight truncate">{subtitle}</p>
      )}
    </div>

    <!-- Dashboard switcher tabs -->
    <div class="hidden sm:flex items-center gap-0.5 bg-zinc-100 dark:bg-zinc-800/60 rounded-lg p-0.5 border border-zinc-200 dark:border-zinc-700 shrink-0">
      <button
        id="dash-btn-main"
        data-dashboard="main"
        type="button"
        title="Main dashboard"
        class="dash-tab active px-2.5 py-1 rounded-md text-xs font-medium transition-colors text-zinc-900 dark:text-zinc-100 bg-white dark:bg-zinc-700 shadow-sm"
      >
        <span class="flex items-center gap-1.5">
          <!-- Grid icon -->
          <svg viewBox="0 0 24 24" fill="none" class="w-3.5 h-3.5" stroke="currentColor" stroke-width="2">
            <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
            <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
          </svg>
          <span class="hidden md:inline">Main</span>
        </span>
      </button>
      <button
        id="dash-btn-url"
        data-dashboard="url"
        type="button"
        title="URL-grouped dashboard"
        class="dash-tab px-2.5 py-1 rounded-md text-xs font-medium transition-colors text-zinc-500 dark:text-zinc-400 hover:text-zinc-700 dark:hover:text-zinc-200"
      >
        <span class="flex items-center gap-1.5">
          <!-- Link icon -->
          <svg viewBox="0 0 24 24" fill="none" class="w-3.5 h-3.5" stroke="currentColor" stroke-width="2">
            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
          </svg>
          <span class="hidden md:inline">By URL</span>
        </span>
      </button>
      <button
        id="dash-btn-status"
        data-dashboard="status"
        type="button"
        title="Status dashboard"
        class="dash-tab px-2.5 py-1 rounded-md text-xs font-medium transition-colors text-zinc-500 dark:text-zinc-400 hover:text-zinc-700 dark:hover:text-zinc-200"
      >
        <span class="flex items-center gap-1.5">
          <!-- Activity icon -->
          <svg viewBox="0 0 24 24" fill="none" class="w-3.5 h-3.5" stroke="currentColor" stroke-width="2">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
          </svg>
          <span class="hidden md:inline">Status</span>
        </span>
      </button>
    </div>

    <!-- Mobile dashboard switcher (compact) -->
    <div class="flex sm:hidden items-center">
      <button
        id="dash-cycle-mobile"
        type="button"
        title="Switch dashboard"
        class="p-1.5 rounded-lg text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 hover:bg-zinc-100 dark:hover:bg-zinc-800 border border-transparent hover:border-zinc-200 dark:hover:border-zinc-700 transition-colors"
      >
        <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4" stroke="currentColor" stroke-width="2">
          <polyline points="17 1 21 5 17 9"/>
          <path d="M3 11V9a4 4 0 0 1 4-4h14"/>
          <polyline points="7 23 3 19 7 15"/>
          <path d="M21 13v2a4 4 0 0 1-4 4H3"/>
        </svg>
      </button>
    </div>

    <!-- Right side controls -->
    <div class="flex items-center gap-1.5 shrink-0">

      <!-- Search bar -->
      <div class="relative flex items-center" id="search-container">
        <input
          id="search-input"
          type="text"
          placeholder="Search services…"
          aria-label="Search services"
          class="hidden w-48 sm:w-56 px-3 py-1.5 pr-8 rounded-lg text-xs bg-zinc-100 dark:bg-zinc-800 border border-zinc-300 dark:border-zinc-600 text-zinc-900 dark:text-zinc-100 placeholder-zinc-400 dark:placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-zinc-400 dark:focus:ring-zinc-500 transition-all"
        />
        <button
          id="search-toggle"
          type="button"
          title="Search services"
          aria-label="Toggle search"
          class="p-1.5 rounded-lg text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 hover:bg-zinc-100 dark:hover:bg-zinc-800 border border-transparent hover:border-zinc-200 dark:hover:border-zinc-700 transition-colors"
        >
          <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/>
            <line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </button>
      </div>

      <!-- Recent items button + dropdown -->
      <div class="relative" id="recent-container">
        <button
          id="recent-toggle"
          type="button"
          title="Recently opened"
          aria-label="Recent items"
          class="p-1.5 rounded-lg text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 hover:bg-zinc-100 dark:hover:bg-zinc-800 border border-transparent hover:border-zinc-200 dark:hover:border-zinc-700 transition-colors"
        >
          <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
        </button>
        <!-- Dropdown -->
        <div
          id="recent-dropdown"
          class="hidden absolute right-0 top-full mt-1.5 w-72 bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-700 rounded-xl shadow-xl shadow-zinc-200/60 dark:shadow-zinc-950/60 z-50 overflow-hidden"
        >
          <div class="px-3 py-2 border-b border-zinc-100 dark:border-zinc-800 flex items-center justify-between">
            <span class="text-xs font-semibold text-zinc-500 dark:text-zinc-400 uppercase tracking-wide">Recent</span>
            <button id="recent-clear" class="text-xs text-zinc-400 hover:text-red-500 dark:hover:text-red-400 transition-colors">Clear</button>
          </div>
          <ul id="recent-list" class="max-h-72 overflow-y-auto py-1">
            <!-- Populated by JS -->
          </ul>
          <div id="recent-empty" class="hidden px-4 py-6 text-center text-xs text-zinc-400 dark:text-zinc-600">
            No recent items
          </div>
        </div>
      </div>

      <!-- View toggle -->
      <button
        id="view-toggle"
        type="button"
        title="Toggle compact view"
        aria-label="Toggle compact view"
        class="p-1.5 rounded-lg text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 hover:bg-zinc-100 dark:hover:bg-zinc-800 border border-transparent hover:border-zinc-200 dark:hover:border-zinc-700 transition-colors"
      >
        <svg id="icon-view-compact" viewBox="0 0 24 24" fill="none" class="w-4 h-4" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="5" x2="21" y2="5"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="19" x2="21" y2="19"/>
        </svg>
        <svg id="icon-view-normal" viewBox="0 0 24 24" fill="none" class="w-4 h-4 hidden" stroke="currentColor" stroke-width="2">
          <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
          <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
        </svg>
      </button>

      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        type="button"
        title="Toggle light/dark mode"
        aria-label="Toggle theme"
        class="p-1.5 rounded-lg text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 hover:bg-zinc-100 dark:hover:bg-zinc-800 border border-transparent hover:border-zinc-200 dark:hover:border-zinc-700 transition-colors"
      >
        <svg id="icon-theme-sun" viewBox="0 0 24 24" fill="none" class="w-4 h-4" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg id="icon-theme-moon" viewBox="0 0 24 24" fill="none" class="w-4 h-4 hidden" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"/>
        </svg>
      </button>

    </div>
  </div>
</header>

<script is:inline>
(function () {
  // ── View toggle ────────────────────────────────────────────────────────────
  function applyView(v) {
    document.documentElement.dataset.view = v;
    var isCompact = v === 'compact';
    var iconC = document.getElementById('icon-view-compact');
    var iconN = document.getElementById('icon-view-normal');
    if (iconC) iconC.classList.toggle('hidden', isCompact);
    if (iconN) iconN.classList.toggle('hidden', !isCompact);
    try { localStorage.setItem('dockboard_view', v); } catch (_) {}
  }
  applyView(document.documentElement.dataset.view || 'normal');
  document.getElementById('view-toggle')?.addEventListener('click', function () {
    applyView(document.documentElement.dataset.view === 'compact' ? 'normal' : 'compact');
  });

  // ── Theme toggle ───────────────────────────────────────────────────────────
  function applyTheme(t) {
    var isDark = t === 'dark';
    document.documentElement.classList.toggle('dark', isDark);
    var iconS = document.getElementById('icon-theme-sun');
    var iconM = document.getElementById('icon-theme-moon');
    if (iconS) iconS.classList.toggle('hidden', !isDark);
    if (iconM) iconM.classList.toggle('hidden', isDark);
    var metaTheme = document.getElementById('meta-theme-color');
    if (metaTheme) metaTheme.setAttribute('content', isDark ? '#09090b' : '#f4f4f5');
    try { localStorage.setItem('dockboard_theme', t); } catch (_) {}
  }
  applyTheme(document.documentElement.classList.contains('dark') ? 'dark' : 'light');
  document.getElementById('theme-toggle')?.addEventListener('click', function () {
    applyTheme(document.documentElement.classList.contains('dark') ? 'light' : 'dark');
  });

  // ── Dashboard switcher ─────────────────────────────────────────────────────
  var DASHBOARDS = ['main', 'url', 'status'];
  function activateDashboard(name) {
    // Update tab styles
    document.querySelectorAll('.dash-tab').forEach(function(btn) {
      var isActive = btn.dataset.dashboard === name;
      btn.classList.toggle('active', isActive);
      btn.classList.toggle('text-zinc-900', isActive);
      btn.classList.toggle('dark:text-zinc-100', isActive);
      btn.classList.toggle('bg-white', isActive);
      btn.classList.toggle('dark:bg-zinc-700', isActive);
      btn.classList.toggle('shadow-sm', isActive);
      btn.classList.toggle('text-zinc-500', !isActive);
      btn.classList.toggle('dark:text-zinc-400', !isActive);
    });
    // Show/hide dashboard panels
    DASHBOARDS.forEach(function(d) {
      var el = document.getElementById('dashboard-' + d);
      if (el) el.classList.toggle('hidden', d !== name);
    });
    try { localStorage.setItem('dockboard_dashboard', name); } catch(_) {}
    // Trigger render if needed (url/status dashboards)
    var ev = new CustomEvent('dockboard:dashboard', { detail: { name: name } });
    document.dispatchEvent(ev);
  }
  // Init from saved or default
  var savedDash = 'main';
  try { savedDash = localStorage.getItem('dockboard_dashboard') || 'main'; } catch(_) {}
  if (!DASHBOARDS.includes(savedDash)) savedDash = 'main';
  activateDashboard(savedDash);

  document.querySelectorAll('.dash-tab').forEach(function(btn) {
    btn.addEventListener('click', function() { activateDashboard(btn.dataset.dashboard); });
  });
  // Mobile cycle button
  document.getElementById('dash-cycle-mobile')?.addEventListener('click', function() {
    var cur = document.querySelector('.dash-tab.active')?.dataset.dashboard || 'main';
    var idx = DASHBOARDS.indexOf(cur);
    activateDashboard(DASHBOARDS[(idx + 1) % DASHBOARDS.length]);
  });

  // ── Search toggle ──────────────────────────────────────────────────────────
  var searchInput = document.getElementById('search-input');
  var searchToggle = document.getElementById('search-toggle');
  var searchOpen = false;
  function openSearch() {
    if (!searchInput || !searchToggle) return;
    searchOpen = true;
    searchInput.classList.remove('hidden');
    searchInput.focus();
    searchToggle.classList.add('text-zinc-900', 'dark:text-zinc-100');
  }
  function closeSearch() {
    if (!searchInput || !searchToggle) return;
    searchOpen = false;
    searchInput.value = '';
    searchInput.classList.add('hidden');
    searchToggle.classList.remove('text-zinc-900', 'dark:text-zinc-100');
    // Clear search filter
    var ev = new CustomEvent('dockboard:search', { detail: { query: '' } });
    document.dispatchEvent(ev);
  }
  searchToggle?.addEventListener('click', function() {
    if (searchOpen) closeSearch(); else openSearch();
  });
  searchInput?.addEventListener('input', function() {
    var ev = new CustomEvent('dockboard:search', { detail: { query: searchInput.value.trim().toLowerCase() } });
    document.dispatchEvent(ev);
  });
  searchInput?.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeSearch();
  });
  // Close search when clicking outside
  document.addEventListener('click', function(e) {
    var container = document.getElementById('search-container');
    if (searchOpen && container && !container.contains(e.target)) closeSearch();
  });

  // ── Recent items ───────────────────────────────────────────────────────────
  var RECENT_KEY = 'dockboard_recent';
  var MAX_RECENT = 10;
  function loadRecent() {
    try { return JSON.parse(localStorage.getItem(RECENT_KEY) || '[]'); } catch(_) { return []; }
  }
  function saveRecent(items) {
    try { localStorage.setItem(RECENT_KEY, JSON.stringify(items)); } catch(_) {}
  }
  function addRecent(item) {
    var items = loadRecent().filter(function(r) { return r.url !== item.url; });
    items.unshift({ title: item.title, url: item.url, icon: item.icon || '', ts: Date.now() });
    if (items.length > MAX_RECENT) items = items.slice(0, MAX_RECENT);
    saveRecent(items);
    renderRecentList();
  }
  function renderRecentList() {
    var list = document.getElementById('recent-list');
    var empty = document.getElementById('recent-empty');
    if (!list || !empty) return;
    var items = loadRecent();
    list.innerHTML = '';
    if (items.length === 0) { empty.classList.remove('hidden'); return; }
    empty.classList.add('hidden');
    items.forEach(function(item) {
      var li = document.createElement('li');
      li.innerHTML =
        '<a href="' + item.url + '" target="_blank" rel="noopener noreferrer" ' +
        'class="flex items-center gap-2.5 px-3 py-2 hover:bg-zinc-50 dark:hover:bg-zinc-800 transition-colors group recent-item-link" ' +
        'data-url="' + item.url + '" data-title="' + item.title + '" data-icon="' + item.icon + '">' +
        (item.icon
          ? '<img src="/icons/' + item.icon + '" alt="" class="w-5 h-5 rounded object-contain shrink-0" onerror="this.style.display=\'none\'">'
          : '<span class="w-5 h-5 rounded bg-zinc-200 dark:bg-zinc-700 shrink-0"></span>'
        ) +
        '<span class="min-w-0 flex-1">' +
        '<span class="block text-xs font-medium text-zinc-800 dark:text-zinc-200 truncate group-hover:text-zinc-900 dark:group-hover:text-white transition-colors">' + item.title + '</span>' +
        '<span class="block text-[10px] text-zinc-400 dark:text-zinc-500 truncate">' + item.url + '</span>' +
        '</span></a>';
      list.appendChild(li);
    });
  }
  // Toggle dropdown
  var recentOpen = false;
  document.getElementById('recent-toggle')?.addEventListener('click', function(e) {
    e.stopPropagation();
    recentOpen = !recentOpen;
    var dd = document.getElementById('recent-dropdown');
    if (dd) dd.classList.toggle('hidden', !recentOpen);
    if (recentOpen) renderRecentList();
  });
  document.addEventListener('click', function(e) {
    var cont = document.getElementById('recent-container');
    if (recentOpen && cont && !cont.contains(e.target)) {
      recentOpen = false;
      document.getElementById('recent-dropdown')?.classList.add('hidden');
    }
  });
  document.getElementById('recent-clear')?.addEventListener('click', function() {
    saveRecent([]);
    renderRecentList();
  });
  // Expose addRecent globally so index.astro can call it
  window.dockboardAddRecent = addRecent;

  // Initial render
  renderRecentList();
})();
</script>
