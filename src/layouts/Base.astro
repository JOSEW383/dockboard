---
interface Props {
  title?: string;
  favicon?: string;
}
const { title = 'Dockboard', favicon } = Astro.props;
const faviconSrc = favicon ? `/icons/${favicon}` : '/favicon.ico';
---

<!DOCTYPE html>
<html lang="en" class="h-full dark" data-view="normal">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Dockboard — your self-hosted service dashboard" />
    <meta name="theme-color" content="#09090b" id="meta-theme-color" />

    <title>{title}</title>

    <!-- Favicon -->
    <link rel="icon" href={faviconSrc} />
    <link rel="shortcut icon" href={faviconSrc} />

    <!-- PWA -->
    <link rel="manifest" href="/api/manifest" />
    <link rel="apple-touch-icon" href={faviconSrc} />

    <!-- Preconnect for SimpleIcons CDN (icon fallback) -->
    <link rel="preconnect" href="https://cdn.simpleicons.org" crossorigin />

    <!-- Restore theme + view before first paint -->
    <script is:inline>
      (function () {
        var theme = localStorage.getItem('dockboard_theme') || 'dark';
        var view  = localStorage.getItem('dockboard_view')  || 'normal';
        if (theme === 'light') document.documentElement.classList.remove('dark');
        document.documentElement.dataset.view = view;
        var metaTheme = document.getElementById('meta-theme-color');
        if (metaTheme) metaTheme.setAttribute('content', theme === 'light' ? '#f4f4f5' : '#09090b');
      })();
    </script>

    <!-- Base light/dark background — explicit fallback in case Tailwind dark: variants are not yet compiled -->
    <style>
      html.dark  { background-color: #09090b; color-scheme: dark;  }
      html:not(.dark) { background-color: #f4f4f5; color-scheme: light; }
    </style>
  </head>
  <body class="h-full bg-zinc-100 dark:bg-zinc-950 text-zinc-900 dark:text-zinc-100 antialiased">
    <slot />

    <script src="/sw-register.js" is:inline></script>
  </body>
</html>
